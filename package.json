    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "test": "node --test"
  },
  "dependencies": {
    "@vercel/blob": "^2.3.3",
    "vite": "^7.0.0",
    "typescript": "^5.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
