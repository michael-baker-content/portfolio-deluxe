{
  "name": "portfolio",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.6.2",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:3000": "vite --host 127.0.0.1 --port 3000 --strictPort",
    "dev:vercel": "vercel dev",
    "stop:3000": "powershell -ExecutionPolicy Bypass -File scripts/stop-port.ps1 3000",
